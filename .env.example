APP_NAME="File Converter API"
APP_DESCRIPTION="A file conversion REST API built with FastAPI. Supports converting DOCX, XLSX, PDF, images, and text files into multiple formats."
APP_VERSION="1.0.0"

API_PREFIX=/api

ENVIRONMENT=development

LOG_LEVEL=INFO

TEMP_DIR=./temp
OUTPUT_DIR=./output

MAX_FILE_SIZE_MB=20
CONVERSION_TIMEOUT_SECONDS=120
ALLOWED_EXTENSIONS=["pdf","docx","odt","txt","md","html","xlsx","csv","json","jpg","jpeg","png","bmp","tiff"]
ALLOWED_MIME_TYPES=["application/pdf","application/vnd.openxmlformats-officedocument.wordprocessingml.document","text/plain","image/jpeg","image/png","application/vnd.ms-excel","text/csv"]
